# ==========================================
# GLOW 'N' GO BEAUTY & COSMETICS — BACKEND ENVIRONMENT
# ==========================================
# Rename to ".env" and NEVER commit it. Add ".env" to .gitignore.

PORT=5000
NODE_ENV=development
# Comma-separated — add your LAN IP here too if you're testing from a
# phone/tablet on the same WiFi (see README §"Access from mobile devices").
# Example: http://localhost:3000,http://192.168.1.42:3000
CORS_ORIGIN=http://localhost:3000

# --- Database (PostgreSQL + Prisma) ---
# Matches docker-compose.yml's port (5433, not 5432 — see that file for why).
# If you already have Postgres running locally instead, point this at that
# instead and skip docker compose entirely.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/glow_n_go

# --- JWT ---
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# --- Public base URL (used to build the M-Pesa callback URL) ---
# Local dev: run `ngrok http 5000` and paste the https URL here.
BASE_URL=https://YOUR-NGROK-OR-PROD-DOMAIN.example.com

# ==========================================
# EMAIL / SMTP — verification codes, password reset, order confirmation,
# payment receipts, post-delivery feedback requests
# ==========================================
# Leave these blank and the app still works — emails are logged to the
# console instead of sent (useful for local dev). Fill them in to send
# real email. Gmail App Password setup:
#   1. Enable 2FA on the Google account
#   2. Google Account → Security → App passwords → generate one for "Mail"
#   3. Paste the 16-character password as SMTP_PASS (NOT the Gmail login password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=GLOW 'N' GO Beauty & Cosmetics
EMAIL_FROM_ADDR=noreply@glowngo.co.ke

# Where the "payment received" notification goes (the in-app equivalent
# of the SMS Safaricom sends automatically to a real till in production —
# see backend/README-MPESA.md for that distinction).
ADMIN_NOTIFICATION_EMAIL=admin@glowngo.co.ke

# ==========================================
# M-PESA DARAJA — SANDBOX
# ==========================================
MPESA_ENV=sandbox
MPESA_BASE_URL=https://sandbox.safaricom.co.ke

# From your Daraja sandbox app, as provided:
MPESA_CONSUMER_KEY=DOoUIiYZzBtrv0keFZ3GgWYH0EzkCEFBAxaG2jQUo9HNyF9c
MPESA_CONSUMER_SECRET=vttamysyPQywUIgJTGmuMqQKhmG1lzO8Wc0H76BXNbg51A7OkfZTZ7LFGR3qkAmu

# Your Daraja app listed Shortcode/Passkey as "N/A". STK Push CANNOT work
# without both, so this uses Safaricom's published SANDBOX test pair,
# valid for every developer account:
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline

# Your REAL Buy Goods till (6948840) is a PRODUCTION-only value — Daraja's
# sandbox always routes STK pushes to Safaricom's shared sandbox
# shortcode above, never to a real till, no matter what you configure.
# This variable is here for when you complete Safaricom's go-live process
# and switch MPESA_ENV=production — leave it unset for sandbox testing.
# MPESA_TILL_NUMBER=6948840

MPESA_STK_CALLBACK_URL=${BASE_URL}/api/mpesa/callback
MPESA_TIMEOUT_URL=${BASE_URL}/api/mpesa/timeout

# Rename to ".env.local" (Next.js convention). Restart `npm run dev` after
# changing this — Next.js bakes NEXT_PUBLIC_* vars in at build/start time,
# it does not hot-reload them.

# Default: works when you're ONLY ever browsing from this same laptop.
NEXT_PUBLIC_API_URL=http://localhost:5000

# Testing from a phone/tablet on the same WiFi? "localhost" means "this
# device" to whichever device opens the page — your phone has no backend
# running on itself, so every API call silently fails. Fix: replace
# BOTH of the above with your laptop's LAN IP instead (find it with
# `ipconfig` on Windows or `ip addr` / `ifconfig` on Mac/Linux — look for
# something like 192.168.1.42), then:
#   1. NEXT_PUBLIC_API_URL=http://192.168.1.42:5000
#   2. Add that same IP to backend/.env's CORS_ORIGIN (comma-separated)
#   3. On BOTH the laptop and the phone, open http://192.168.1.42:3000
#      (not "localhost") — using the LAN IP works from either device,
#      since the laptop can also reach its own LAN IP fine.
#   4. Make sure your laptop's firewall allows inbound connections on
#      ports 3000 and 5000 (Windows Defender Firewall will usually
#      prompt you the first time — allow it for "Private networks").
# See README §"Access from mobile devices" for the full walkthrough.
